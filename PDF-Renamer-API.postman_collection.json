{
  "info": {
    "name": "PDF Renamer API",
    "description": "Postman collection for the PDF Renamer NestJS backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Upload Documents",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "files",
              "type": "file",
              "src": []
            }
          ]
        },
        "url": {
          "raw": "{{base_url}}/documents/upload",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "upload"
          ]
        }
      }
    },
    {
      "name": "Get All Documents",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/documents",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents"
          ]
        }
      }
    },
    {
      "name": "Get Document by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/documents/{{document_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "{{document_id}}"
          ]
        }
      }
    },
    {
      "name": "Get Document Download URL",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/documents/{{document_id}}/download",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "{{document_id}}",
            "download"
          ]
        }
      }
    },
    {
      "name": "Retry Document Processing",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/documents/{{document_id}}/retry",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "{{document_id}}",
            "retry"
          ]
        }
      }
    },
    {
      "name": "Update Document Filename",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"filename\": \"new-updated-filename.pdf\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/documents/{{document_id}}/filename",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "{{document_id}}",
            "filename"
          ]
        }
      }
    },
    {
      "name": "Delete Document",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/documents/{{document_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "{{document_id}}"
          ]
        }
      }
    },
    {
      "name": "Cancel Document Processing",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/documents/{{document_id}}/cancel",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "{{document_id}}",
            "cancel"
          ]
        }
      }
    },
    {
      "name": "Get Stuck Documents",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/documents/stuck",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "stuck"
          ]
        }
      }
    },
    {
      "name": "Reconcile Stuck Documents",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/documents/stuck/reconcile",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "stuck",
            "reconcile"
          ]
        }
      }
    },
    {
      "name": "Get AI Providers",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/ai/providers",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "ai",
            "providers"
          ]
        }
      }
    },
    {
      "name": "Check AI Provider Health",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/ai/providers/openai/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "ai",
            "providers",
            "openai",
            "health"
          ]
        }
      }
    },
    {
      "name": "List AI Evaluations",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/documents/{{document_id}}/ai-evaluations",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "{{document_id}}",
            "ai-evaluations"
          ]
        }
      }
    },
    {
      "name": "Run Single AI Evaluation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"provider\": \"openai\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/documents/{{document_id}}/ai-evaluations",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "{{document_id}}",
            "ai-evaluations"
          ]
        }
      }
    },
    {
      "name": "Run Batch AI Evaluation",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"runs\": [\n        { \"provider\": \"openai\" },\n        { \"provider\": \"ollama\" }\n    ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/documents/{{document_id}}/ai-evaluations/batch",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "{{document_id}}",
            "ai-evaluations",
            "batch"
          ]
        }
      }
    },
    {
      "name": "Get Fast Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        }
      }
    },
    {
      "name": "Get Detailed Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health/detailed",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health",
            "detailed"
          ]
        }
      }
    },
    {
      "name": "Get Prometheus Metrics",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/metrics",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "metrics"
          ]
        }
      }
    },
    {
      "name": "Stream All Document Events (SSE)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/documents/events",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "events"
          ]
        }
      }
    },
    {
      "name": "Stream Single Document Events (SSE)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/documents/{{document_id}}/events",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "documents",
            "{{document_id}}",
            "events"
          ]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "document_id",
      "value": "replace-with-document-id",
      "type": "string"
    }
  ]
}
