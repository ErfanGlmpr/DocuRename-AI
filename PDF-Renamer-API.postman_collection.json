{
  "info": {
    "name": "PDF Renamer API",
    "description": "Postman collection for the PDF Renamer NestJS backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", json.accessToken);",
                  "}",
                  "if (json.refreshToken) {",
                  "    pm.collectionVariables.set(\"refreshToken\", json.refreshToken);",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"MySecretPass1!\",\n  \"name\": \"Jane Doe\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", json.accessToken);",
                  "}",
                  "if (json.refreshToken) {",
                  "    pm.collectionVariables.set(\"refreshToken\", json.refreshToken);",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"MySecretPass1!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.accessToken) {",
                  "    pm.collectionVariables.set(\"accessToken\", json.accessToken);",
                  "}",
                  "if (json.refreshToken) {",
                  "    pm.collectionVariables.set(\"refreshToken\", json.refreshToken);",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          }
        },
        {
          "name": "Logout User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200 || pm.response.code === 201) {",
                  "    pm.collectionVariables.set(\"accessToken\", \"\");",
                  "    pm.collectionVariables.set(\"refreshToken\", \"\");",
                  "}"
                ],
                "type": "javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "logout"
              ]
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{accessToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Uploads",
      "item": [
        {
          "name": "Upload PDFs",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "files",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/documents/upload",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "upload"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "List Documents",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/documents",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents"
              ]
            }
          }
        },
        {
          "name": "Get Document Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/documents/{{documentId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "{{documentId}}"
              ]
            }
          }
        },
        {
          "name": "Download Renamed PDF",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/documents/{{documentId}}/download",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "{{documentId}}",
                "download"
              ]
            }
          }
        },
        {
          "name": "Retry Failed Document",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/documents/{{documentId}}/retry",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "{{documentId}}",
                "retry"
              ]
            }
          }
        },
        {
          "name": "Cancel Processing Document",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/documents/{{documentId}}/cancel",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "{{documentId}}",
                "cancel"
              ]
            }
          }
        },
        {
          "name": "List Stuck Documents",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/documents/stuck",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "stuck"
              ]
            }
          }
        },
        {
          "name": "Reconcile Stuck Documents",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/documents/stuck/reconcile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "stuck",
                "reconcile"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "AI Providers",
      "item": [
        {
          "name": "List AI Providers",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/ai/providers",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ai",
                "providers"
              ]
            }
          }
        },
        {
          "name": "Check Provider Health",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/ai/providers/openai/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "ai",
                "providers",
                "openai",
                "health"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "AI Evaluations",
      "item": [
        {
          "name": "List Evaluation Runs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/documents/{{documentId}}/ai-evaluations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "{{documentId}}",
                "ai-evaluations"
              ]
            }
          }
        },
        {
          "name": "Run Model Evaluation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"provider\": \"openai\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/documents/{{documentId}}/ai-evaluations",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "{{documentId}}",
                "ai-evaluations"
              ]
            }
          }
        },
        {
          "name": "Run Batch Model Evaluation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"runs\": [\n        { \"provider\": \"openai\" },\n        { \"provider\": \"ollama\" }\n    ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/documents/{{documentId}}/ai-evaluations/batch",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "{{documentId}}",
                "ai-evaluations",
                "batch"
              ]
            }
          }
        },
        {
          "name": "Get Evaluation Run",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/documents/{{documentId}}/ai-evaluations/{{evaluation_id}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "documents",
                "{{documentId}}",
                "ai-evaluations",
                "{{evaluation_id}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Organization Overview",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/admin/overview",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "admin",
                "overview"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Health and Metrics",
      "item": [
        {
          "name": "Basic Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "Detailed Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health/detailed",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health",
                "detailed"
              ]
            }
          }
        },
        {
          "name": "Metrics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Metrics-Token",
                "value": "{{metrics_token}}",
                "type": "text",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/metrics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "metrics"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "documentId",
      "value": "replace-with-document-id",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "organizationId",
      "value": "",
      "type": "string"
    },
    {
      "key": "metrics_token",
      "value": "your-metrics-token-here",
      "type": "string"
    },
    {
      "key": "evaluation_id",
      "value": "replace-with-evaluation-id",
      "type": "string"
    },
    {
      "key": "provider",
      "value": "openai",
      "type": "string"
    },
    {
      "key": "model",
      "value": "gpt-4o",
      "type": "string"
    }
  ]
}