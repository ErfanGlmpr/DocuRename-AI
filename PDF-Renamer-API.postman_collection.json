            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"runs\": [\n        { \"provider\": \"openai\" },\n        { \"provider\": \"ollama\" }\n    ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/documents/{{document_id}}/ai-evaluations/batch",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "{{document_id}}",
                "ai-evaluations",
                "batch"
              ]
