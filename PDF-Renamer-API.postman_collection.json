                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"provider\": \"openai\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/documents/{{document_id}}/ai-evaluations",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "{{document_id}}",
                "ai-evaluations"
              ]
            }
          }
        },
