              ]
            }
          }
        },
        {
          "name": "Stream Single Document Events (SSE)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/documents/{{document_id}}/events",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "{{document_id}}",
                "events"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "System & Monitoring",
      "item": [
        {
          "name": "Get Fast Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            }
          }
        },
        {
          "name": "Get Detailed Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health/detailed",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health",
                "detailed"
              ]
            }
          }
        },
        {
          "name": "Get Prometheus Metrics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-Metrics-Token",
                "value": "{{metrics_token}}",
                "type": "text",
                "disabled": true
              }
            ],
            "url": {
              "raw": "{{base_url}}/metrics",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "metrics"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "document_id",
      "value": "replace-with-document-id",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "refreshToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "organization_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "metrics_token",
      "value": "your-metrics-token-here",
      "type": "string"
    }
  ]
}
