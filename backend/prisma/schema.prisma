generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Document {
  id                   String              @id @default(uuid())
  originalName         String
  generatedName        String?
  finalName            String?
  mimeType             String
  sizeBytes            Int
  sha256               String
  status               DocumentStatus      @default(UPLOADED)
  storageKey           String
  finalStorageKey      String?
  pageCount            Int?
  detectedLanguage     String?
  aiProvider           String?
  aiModel              String?
  title                String?
  category             String?
  documentDate         String?
  issuer               String?
  recipient            String?
  referenceNumber      String?
  summary              String?
  confidence           Float?
  errorMessage         String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  aiInputMode          AiInputMode         @default(REDACTED_TEXT)
  piiDetected          Boolean             @default(false)
  piiEntityCount       Int                 @default(0)
  piiProcessedAt       DateTime?
  piiTokenMapEncrypted Json?
  privacyMode          PrivacyMode         @default(REDACTED)
  redactedText         String?
  processingDuration   Int?
  promptTokens         Int?
  completionTokens     Int?
  totalTokens          Int?
  evaluationRuns       AiEvaluationRun[]
}

model AuditLog {
  id         String   @id @default(uuid())
  documentId String?
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())
}

model AiEvaluationRun {
  id                String             @id @default(uuid())
  documentId        String
  document          Document           @relation(fields: [documentId], references: [id])
  provider          String
  model             String
  status            AiEvaluationStatus @default(PENDING)
  title             String?
  category          String?
  documentDate      String?
  issuer            String?
  recipient         String?
  referenceNumber   String?
  suggestedFilename String?
  confidence        Float?
  summary           String?
  language          String?
  promptTokens      Int?
  completionTokens  Int?
  totalTokens       Int?
  latencyMs         Int?
  errorMessage      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

enum DocumentStatus {
  UPLOADED
  QUEUED
  EXTRACTING_TEXT
  ANALYZING_WITH_AI
  RENAMING
  COMPLETED
  FAILED
  NEEDS_REVIEW
}

enum PrivacyMode {
  NONE
  REDACTED
}

enum AiInputMode {
  RAW_TEXT
  REDACTED_TEXT
  MINIMIZED_REDACTED_TEXT
}

enum AiEvaluationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
