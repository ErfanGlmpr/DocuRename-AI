generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth / Multi-Tenant Models ───────────────────────────────────────────────

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  name             String?
  passwordHash     String
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  memberships OrganizationMember[]
  documents   Document[]
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   OrganizationMember[]
  documents Document[]
}

model OrganizationMember {
  id             String           @id @default(uuid())
  userId         String
  organizationId String
  role           OrganizationRole
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

// ─── Document Models ──────────────────────────────────────────────────────────

model Document {
  id                   String          @id @default(uuid())
  originalName         String
  generatedName        String?
  finalName            String?
  mimeType             String
  sizeBytes            Int
  sha256               String
  status               DocumentStatus  @default(UPLOADED)
  storageKey           String
  finalStorageKey      String?
  pageCount            Int?
  detectedLanguage     String?
  aiProvider           String?
  aiModel              String?
  title                String?
  category             String?
  documentDate         String?
  issuer               String?
  recipient            String?
  referenceNumber      String?
  summary              String?
  confidence           Float?
  errorMessage         String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  aiInputMode          AiInputMode     @default(REDACTED_TEXT)
  piiDetected          Boolean         @default(false)
  piiEntityCount       Int             @default(0)
  piiProcessedAt       DateTime?
  piiTokenMapEncrypted Json?
  privacyMode          PrivacyMode     @default(REDACTED)
  redactedText         String?
  processingDuration   Int?
  promptTokens         Int?
  completionTokens     Int?
  totalTokens          Int?
  // Phase 4: OCR
  ocrUsed              Boolean         @default(false)
  ocrTextLength        Int?
  // Phase 4: Quality scoring
  qualityScore         Int?
  // Phase 4: Document chunking
  chunkCount           Int?
  inputTextLength      Int?
  processingDurationMs Int?
  // Phase 4: Virus scanning
  virusScanned         Boolean         @default(false)
  virusScanResult      String?
  // Phase 5: Tenant ownership (required as of Ticket 2.3)
  userId               String
  organizationId       String

  user         User              @relation(fields: [userId], references: [id])
  organization Organization      @relation(fields: [organizationId], references: [id])
  evaluationRuns AiEvaluationRun[]

  @@index([organizationId])
  @@index([userId])
}

model AuditLog {
  id             String   @id @default(uuid())
  documentId     String?
  action         String
  metadata       Json?
  createdAt      DateTime @default(now())
  // Phase 5: Actor context
  actorUserId    String?
  organizationId String?
}

model AiEvaluationRun {
  id                String             @id @default(uuid())
  documentId        String
  document          Document           @relation(fields: [documentId], references: [id])
  provider          String
  model             String
  status            AiEvaluationStatus @default(PENDING)
  title             String?
  category          String?
  documentDate      String?
  issuer            String?
  recipient         String?
  referenceNumber   String?
  suggestedFilename String?
  confidence        Float?
  summary           String?
  language          String?
  promptTokens      Int?
  completionTokens  Int?
  totalTokens       Int?
  latencyMs         Int?
  errorMessage      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  // Phase 5: Actor context
  actorUserId       String?
  organizationId    String?
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum DocumentStatus {
  UPLOADED
  QUEUED
  VIRUS_SCANNING
  EXTRACTING_TEXT
  ANALYZING_WITH_AI
  RENAMING
  COMPLETED
  FAILED
  NEEDS_REVIEW
  INFECTED
}

enum PrivacyMode {
  NONE
  REDACTED
}

enum AiInputMode {
  RAW_TEXT
  REDACTED_TEXT
  MINIMIZED_REDACTED_TEXT
}

enum AiEvaluationStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}
