DATABASE_URL=postgresql://app:app@localhost:5434/pdf_ai
REDIS_HOST=localhost
REDIS_PORT=6379

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123
S3_BUCKET=documents
S3_FORCE_PATH_STYLE=true

MAX_UPLOAD_SIZE_MB=25

AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b
AI_CONFIDENCE_REVIEW_THRESHOLD=0.7

# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_MODEL=qwen3:4b-instruct
# OLLAMA_MODEL=gemma3:4b
# OLLAMA_MODEL=llama3.2:3b

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com

# Mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# OpenAI-compatible
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=
OPENAI_COMPATIBLE_BASE_URL=http://localhost:8000/v1

# Shared AI settings
AI_REQUEST_TIMEOUT_MS=180000
AI_TEMPERATURE=0
AI_MAX_OUTPUT_TOKENS=2048
AI_ENABLE_PROVIDER_FALLBACK=false
AI_FALLBACK_PROVIDER=ollama

# Phase 2 Privacy Settings
PII_REDACTION_ENABLED=true
# Key must be base64 encoded 32-byte key. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PII_ENCRYPTION_KEY=J5CmUQJIJDuiiT+JmEza46XuYlbAMiIx0EkwHAWLcog=
AI_INPUT_MAX_CHARS=12000
PII_STORE_REDACTED_TEXT=true
PII_STORE_RAW_EXTRACTED_TEXT=true
